# ==============================================================================
# BotChatWhatsAppPizzaria - Configuração de Ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env real no repositório!
# ==============================================================================

# ------------------------------------------------------------------------------
# APP
# ------------------------------------------------------------------------------
APP_ENV=development          # development, staging, production
DEBUG=true
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json              # json, text

# ------------------------------------------------------------------------------
# WHATSAPP BUSINESS API (Meta Developers)
# ------------------------------------------------------------------------------
# Obtenha em: https://developers.facebook.com/apps/
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao_aqui
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxx
WHATSAPP_APP_SECRET=seu_app_secret_aqui

# ------------------------------------------------------------------------------
# GOOGLE GEMINI AI
# ------------------------------------------------------------------------------
# Obtenha em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-pro

# ------------------------------------------------------------------------------
# DATABASE (SQLite local)
# ------------------------------------------------------------------------------
SQLITE_DB_PATH=pizzaria.db

# ------------------------------------------------------------------------------
# GOOGLE SHEETS (Opcional)
# ------------------------------------------------------------------------------
# 1. Crie Service Account no Google Cloud Console
# 2. Ative Google Sheets API e Drive API
# 3. Compartilhe a planilha com o email do service account
# 4. Salve credentials.json na raiz do projeto
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_SHEETS_NAME=Pedidos da Pizzaria

# ------------------------------------------------------------------------------
# REDIS (Sessões + Celery)
# ------------------------------------------------------------------------------
# Desenvolvimento local:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Produção (use URL completa):
# REDIS_URL=redis://:senha@host:6379/0

# Celery broker/backend (separados para isolamento)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------------------------
# PIX
# ------------------------------------------------------------------------------
PIX_KEY=xxx.xxx.xxx-xx (CPF)

# ------------------------------------------------------------------------------
# SESSION
# ------------------------------------------------------------------------------
SESSION_TTL_SECONDS=1800       # 30 minutos
SESSION_PREFIX=pizzaria:session:

# ==============================================================================
# EXEMPLO DE PRODUÇÃO (descomente e ajuste)
# ==============================================================================
# APP_ENV=production
# DEBUG=false
# LOG_LEVEL=WARNING
# REDIS_HOST=redis-producao.xxxxxx.use1.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=senha_muito_forte_aqui
# CELERY_BROKER_URL=redis://:senha_muito_forte_aqui@redis-producao.xxxxxx.use1.cache.amazonaws.com:6379/1
# CELERY_RESULT_BACKEND=redis://:senha_muito_forte_aqui@redis-producao.xxxxxx.use1.cache.amazonaws.com:6379/2
# SESSION_TTL_SECONDS=3600